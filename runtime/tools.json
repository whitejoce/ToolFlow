{
  "name": "double",
  "entry": "main.py:run",
  "input_schema": {
    "type": "object",
    "properties": {
      "number": {
        "type": "number",
        "description": "The number to be doubled"
      }
    },
    "required": ["number"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "result": {
        "type": "number",
        "description": "The doubled number"
      }
    },
    "required": ["result"]
  },
  "code": "def run(input):\n    number = input['number']\n    result = number * 2\n    return result",
  "dependencies": ["requests", "pandas"]
}